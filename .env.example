# Public site URL (required for WhatsApp/social link previews)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Use either the new publishable key OR the legacy anon key:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Use either the new secret key OR the legacy service_role key (server only, never expose):
SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin dashboard password
ADMIN_PASSWORD=choose-a-strong-password
